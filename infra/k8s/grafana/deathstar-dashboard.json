{
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts"
        }
      }
    ],
    "editable": true,
    "cursorSync": "Off",
  
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "title": "RPS - Requests per Second",
          "id": 1,
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "refId": "A",
                    "query": {
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "sum(rate(http_requests_total{path=\"/deathstar-analysis\"}[5m]))"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
  
      "panel-2": {
        "kind": "Panel",
        "spec": {
          "title": "Error Rate",
          "id": 2,
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "refId": "A",
                    "query": {
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "sum(rate(http_requests_total{status!=\"200\",path=\"/deathstar-analysis\"}[5m])) / sum(rate(http_requests_total{path=\"/deathstar-analysis\"}[5m]))"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
  
      "panel-3": {
        "kind": "Panel",
        "spec": {
          "title": "Latency P95",
          "id": 3,
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "refId": "A",
                    "query": {
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
  
      "panel-4": {
        "kind": "Panel",
        "spec": {
          "title": "Cache Hits",
          "id": 4,
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "refId": "A",
                    "query": {
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "sum(rate(cache_hits_total[5m]))"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
  
      "panel-5": {
        "kind": "Panel",
        "spec": {
          "title": "Cache Misses",
          "id": 5,
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "refId": "A",
                    "query": {
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "sum(rate(cache_miss_total[5m]))"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
  
      "panel-6": {
        "kind": "Panel",
        "spec": {
          "title": "Success Rate (SLO)",
          "id": 6,
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "refId": "A",
                    "query": {
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "sum(rate(http_requests_total{status=\"200\",path=\"/deathstar-analysis\"}[5m])) / sum(rate(http_requests_total{path=\"/deathstar-analysis\"}[5m]))"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
  
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          { "kind": "GridLayoutItem", "spec": { "element": { "name": "panel-1" }, "x": 0, "y": 0, "width": 12, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "name": "panel-2" }, "x": 12, "y": 0, "width": 12, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "name": "panel-3" }, "x": 0, "y": 8, "width": 24, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "name": "panel-4" }, "x": 0, "y": 16, "width": 12, "height": 6 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "name": "panel-5" }, "x": 12, "y": 16, "width": 12, "height": 6 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "name": "panel-6" }, "x": 0, "y": 22, "width": 24, "height": 8 } }
        ]
      }
    },
  
    "timeSettings": {
      "from": "now-15m",
      "to": "now",
      "autoRefresh": "5s"
    },
  
    "title": "Deathstar API - SRE Overview (Production Ready)",
    "tags": ["sre", "deathstar", "observability", "helm-ready"]
  }