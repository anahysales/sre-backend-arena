{
  "dashboard": {
    "id": null,
    "title": "Death Star API - SRE Dashboard",
    "tags": ["sre", "deathstar", "observability"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "type": "graph",
        "title": "RPS - Requests per Second",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[1m]))",
            "legendFormat": "RPS"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Error Rate",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status!=\"200\"}[5m])) / sum(rate(http_requests_total[5m]))",
            "legendFormat": "Error Rate"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Latency p95",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95 latency"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Cache Hit Rate",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_miss_total[5m]))",
            "legendFormat": "Hit Rate"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Cache Miss Rate",
        "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(cache_miss_total[5m])",
            "legendFormat": "Miss Rate"
          }
        ]
      },
      {
        "type": "graph",
        "title": "HTTP Requests Total",
        "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m]))",
            "legendFormat": "requests"
          }
        ]
      }
    ]
  },
  "overwrite": true
}