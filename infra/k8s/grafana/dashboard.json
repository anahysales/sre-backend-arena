{
  "title": "Deathstar API - SRE Observability Dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [

    {
      "type": "timeseries",
      "title": "Throughput (RPS)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "job:http_requests:rps",
          "legendFormat": "requests/sec"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Error Rate (SLO)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "job:http_error_rate",
          "legendFormat": "error rate"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Latency p99",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "job:http_request_duration_seconds:p99",
          "legendFormat": "p99 latency"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Error Budget (Derived)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "1 - job:http_error_rate",
          "legendFormat": "remaining budget"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Cache Performance",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "cache_hits_total",
          "legendFormat": "hits"
        },
        {
          "expr": "cache_miss_total",
          "legendFormat": "misses"
        }
      ]
    }

  ]
}